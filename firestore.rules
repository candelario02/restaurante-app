rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 🔒 FUNCIONES GLOBALES DE APOYO
    function estaAutenticado() {
      return request.auth != null;
    }

    // Corregimos la ruta: Ahora busca al usuario DENTRO del restaurante específico
    function esAdminDelRestaurante(restId) {
      let data = get(/databases/$(database)/documents/restaurantes/$(restId)/usuarios_admin/$(request.auth.token.email)).data;
      return data.rol == "admin" || data.rol == "superadmin";
    }

    // 1. 👨‍💼 LOGIN / PERFIL (Permitir lectura para que el sistema cargue el perfil)
    // Se mantiene abierto el paso inicial, pero se protege la escritura
    match /usuarios_admin/{email} {
      allow read: if true; 
      allow write: if false; // Solo se gestionan desde dentro de cada restaurante
    }

    // 2. 🏗️ ESTRUCTURA JERÁRQUICA (RESTAURANTES)
    match /restaurantes/{restId} {
      
      allow read: if true;

      // 🍽️ PRODUCTOS
      match /productos/{docId} {
        allow read: if true; // Clientes pueden ver el menú
        // Solo el admin de ESTE restaurante puede editar
        allow write: if estaAutenticado() && esAdminDelRestaurante(restId);
      }

      // 📝 PEDIDOS (Mantenemos tu lógica intacta para no romper adicionales/reseñas)
      match /pedidos/{docId} {
        allow read, create: if true;
        allow update: if estaAutenticado() || esAdicional() || esSoloResena();
        allow delete: if estaAutenticado() && esAdminDelRestaurante(restId);
      }

      // 👤 USUARIOS DEL STAFF (Gestión interna)
      match /usuarios_admin/{email} {
        // Un admin puede gestionar su propio personal si está en su nodo
        allow read, write: if estaAutenticado() && (request.auth.token.email == email || esAdminDelRestaurante(restId));
      }
    }

    // 🔒 FUNCIONES DE VALIDACIÓN DE PEDIDOS (INTACTAS)
    function esAdicional() {
      return resource.data.estado == 'pendiente' && 
             request.resource.data.diff(resource.data).affectedKeys()
             .hasAny(['items', 'total', 'fechaActualizacion', 'estado']);
    }

    function esSoloResena() {
      return request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['rating', 'resena', 'fechaResena', 'finalizadoCliente']);
    }

    // ⚙️ CONFIGURACIONES
    match /configuraciones/{docId} {
      allow read: if true;
      allow write: if estaAutenticado() && esAdminDelRestaurante(docId);
    }
  }
}