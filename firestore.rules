rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 🔒 FUNCIONES GLOBALES DE APOYO
    function estaAutenticado() {
      return request.auth != null;
    }

    function getUsuarioData() {
      return get(/databases/$(database)/documents/usuarios_admin/$(request.auth.token.email)).data;
    }

    function esAdmin() {
      let data = getUsuarioData();
      return data.rol == "admin" || data.rol == "superadmin";
    }

    // 👨‍💼 USUARIOS ADMIN
    match /usuarios_admin/{email} {
      allow read: if estaAutenticado() && (
        request.auth.token.email == email || 
        (getUsuarioData().rol == "admin" && getUsuarioData().restauranteId == resource.data.restauranteId)
      );

      allow create, update: if estaAutenticado() && 
        esAdmin() && 
        getUsuarioData().restauranteId == request.resource.data.restauranteId;

      allow delete: if estaAutenticado() && 
        esAdmin() && 
        getUsuarioData().restauranteId == resource.data.restauranteId;
    }

    // 🍽️ PRODUCTOS
    match /productos/{docId} {
      allow read: if true; // ✅ Público para QR

      allow create: if estaAutenticado() && 
                    esAdmin() && 
                    getUsuarioData().restauranteId == request.resource.data.restauranteId;

      allow update, delete: if estaAutenticado() && 
                            esAdmin() && 
                            getUsuarioData().restauranteId == resource.data.restauranteId;
    }

 // 📝 PEDIDOS (Actualizado para permitir adicionales y reseñas)
match /restaurantes/{restId}/pedidos/{docId} {
  
  allow read, create: if true; 
  
  allow update: if 
    // Opción A: Es un Admin logueado
    estaAutenticado() || 
    // Opción B: Es un cliente agregando adicionales (items/total)
    esAdicional() ||
    // Opción C: Es un cliente dejando su reseña final
    esSoloResena();
  
  allow delete: if estaAutenticado() && esAdmin();
}

// 🔒 NUEVA FUNCIÓN PARA ADICIONALES
// Permite al cliente editar items y total, pero SOLO si el pedido sigue pendiente
function esAdicional() {
  return resource.data.estado == 'pendiente' && 
         request.resource.data.diff(resource.data).affectedKeys()
         .hasAny(['items', 'total', 'fechaActualizacion', 'estado']);
}

// 🔒 TU FUNCIÓN DE RESEÑA (Se mantiene igual, es correcta)
function esSoloResena() {
  return request.resource.data.diff(resource.data).affectedKeys()
    .hasOnly(['rating', 'resena', 'fechaResena', 'finalizadoCliente']);
}

    // ⚙️ CONFIGURACIONES
    match /configuraciones/{docId} {
      allow read: if true;
      allow write: if estaAutenticado() && 
                   getUsuarioData().restauranteId == docId;
    }
  }
}