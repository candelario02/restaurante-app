rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 🔒 FUNCIONES DE APOYO
    function estaAutenticado() {
      return request.auth != null;
    }

    // Usamos el ID del documento directamente si coincide con el email
    function datosUsuario() {
      return get(/databases/$(database)/documents/usuarios_admin/$(request.auth.token.email)).data;
    }

    // REVISIÓN PROFESIONAL: Permite tanto admin como superadmin
    function esAdminDelRestaurante(resId) {
      let user = datosUsuario();
      return estaAutenticado() && 
             user.restauranteId == resId && 
             (user.rol == "admin" || user.rol == "superadmin");
    }

    function esPersonalDelRestaurante(resId) {
      let user = datosUsuario();
      return estaAutenticado() && 
             user.restauranteId == resId && 
             (user.rol == "admin" || user.rol == "mozo" || user.rol == "superadmin");
    }

    // 🍽️ PRODUCTOS
    match /productos/{docId} {
      allow read: if true; 
      // Usamos get() para validar el ID del restaurante si es una actualización
    allow create: if request.auth != null && request.resource.data.restauranteId != null;
     allow update, delete: if request.auth != null && resource.data.restauranteId != null;
    }

    // 👨‍💼 USUARIOS ADMIN
    match /usuarios_admin/{email} {
      allow read: if estaAutenticado(); 
      allow write: if estaAutenticado() && (request.auth.token.email == email || datosUsuario().rol == "superadmin");
    }
    
    // 📝 PEDIDOS
    match /pedidos/{docId} {
      allow create, read: if true; 
      allow update: if esPersonalDelRestaurante(resource.data.restauranteId);
      allow delete: if esAdminDelRestaurante(resource.data.restauranteId);
    }

    // ⚙️ CONFIGURACIONES
    match /configuraciones/{docId} {
      allow read: if true;
      allow write: if esAdminDelRestaurante(docId);
    }
  }
}