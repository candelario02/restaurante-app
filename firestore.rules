rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 🔒 FUNCIONES DE APOYO LIGERAS
    function estaAutenticado() {
      return request.auth != null;
    }

    // Comprobamos el rol directamente desde el documento del usuario logueado
    function tieneRol(rolRequerido) {
      let u = get(/databases/$(database)/documents/usuarios_admin/$(request.auth.token.email)).data;
      return u.rol == rolRequerido || u.rol == "superadmin";
    }

// 👨‍💼 USUARIOS ADMIN
match /usuarios_admin/{email} {
  // LECTURA: Ya la tienes bien
  allow read: if estaAutenticado() && (
    request.auth.token.email == email || 
    (
      get(/databases/$(database)/documents/usuarios_admin/$(request.auth.token.email)).data.rol == "admin" &&
      get(/databases/$(database)/documents/usuarios_admin/$(request.auth.token.email)).data.restauranteId == resource.data.restauranteId
    )
  );

  // ESCRITURA: Separada para manejar borrados
  // 1. Para CREAR o ACTUALIZAR: Validamos los datos entrantes (request.resource)
  allow create, update: if estaAutenticado() && 
    get(/databases/$(database)/documents/usuarios_admin/$(request.auth.token.email)).data.rol == "admin" &&
    get(/databases/$(database)/documents/usuarios_admin/$(request.auth.token.email)).data.restauranteId == request.resource.data.restauranteId;

  // 2. Para BORRAR: Validamos los datos existentes (resource)
  allow delete: if estaAutenticado() && 
    get(/databases/$(database)/documents/usuarios_admin/$(request.auth.token.email)).data.rol == "admin" &&
    get(/databases/$(database)/documents/usuarios_admin/$(request.auth.token.email)).data.restauranteId == resource.data.restauranteId;
}

    // 🍽️ PRODUCTOS
  match /productos/{docId} {
  allow read: if true; 
  
  // Para crear: validamos el dato que entra
  allow create: if estaAutenticado() && 
                get(/databases/$(database)/documents/usuarios_admin/$(request.auth.token.email)).data.restauranteId == request.resource.data.restauranteId;

  // Para borrar o editar: validamos contra el dato que YA EXISTE en Firestore
  allow update, delete: if estaAutenticado() && 
                        get(/databases/$(database)/documents/usuarios_admin/$(request.auth.token.email)).data.restauranteId == resource.data.restauranteId;
}


 // 📝 PEDIDOS
match /pedidos/{document=**} {
  allow read, create: if true; 
  allow update, delete: if estaAutenticado();
}

match /restaurantes/{restId}/pedidos/{document=**} {
  allow read, create: if true;
  allow update, delete: if estaAutenticado();
}

    // ⚙️ CONFIGURACIONES
    match /configuraciones/{docId} {
      allow read: if true;
      allow write: if estaAutenticado() && 
                   get(/databases/$(database)/documents/usuarios_admin/$(request.auth.token.email)).data.restauranteId == docId;
    }
  }
}