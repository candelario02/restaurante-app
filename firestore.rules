rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 🔒 FUNCIONES DE APOYO
    function estaAutenticado() {
      return request.auth != null;
    }

    function esAdminDelRestaurante(restId) {
      let emailLimpio = request.auth.token.email.lower();
      let adminPath = /databases/$(database)/documents/restaurantes/$(restId)/usuarios_admin/$(emailLimpio);
      return estaAutenticado() && exists(adminPath) && get(adminPath).data.rol in ["admin", "superadmin"];
    }

    // 📂 ESTRUCTURA JERÁRQUICA (image_8e5ade.png)
    match /restaurantes/{restId} {
      allow read: if true;

      // 🍽️ PRODUCTOS
      match /productos/{docId} {
        // El Admin ve todo. El cliente solo ve lo que tiene 'disponible: true'
        allow read: if esAdminDelRestaurante(restId) || resource.data.disponible == true;
        allow write: if esAdminDelRestaurante(restId);
      }
       // 📦 INVENTARIO (Control de Stock)
    match /insumos/{docId} {
        allow read, write: if esAdminDelRestaurante(restId);
    }
    
    // Reglas para el historial de movimientos
    match /historial_movimientos/{docId} {
        allow read, write: if esAdminDelRestaurante(restId);
    }allow read, write: if esAdminDelRestaurante(restId);
    }


      // 📝 PEDIDOS
      match /pedidos/{docId} {
        allow read, create: if true;
        // Permitimos update si: 1. Es admin, 2. Es una reseña, 3. Es el cliente modificando un pedido pendiente
        allow update: if esAdminDelRestaurante(restId) || esSoloResena() || esModificacionCliente();
        allow delete: if esAdminDelRestaurante(restId);
      }

      // ⚙️ CONFIGURACIONES
      match /configuraciones/{docId} {
        allow read: if true;
        allow write: if esAdminDelRestaurante(restId);
      }
      
      // 👤 STAFF
      match /usuarios_admin/{email} {
        allow read: if estaAutenticado() && (request.auth.token.email.lower() == email.lower() || esAdminDelRestaurante(restId));
        allow write: if esAdminDelRestaurante(restId);
      }
    }

    // 🔥 FUNCIONES DE VALIDACIÓN PARA PEDIDOS
    function esModificacionCliente() {
      // El cliente puede actualizar su pedido solo si el estado actual en DB es 'pendiente'
      return resource.data.estado == 'pendiente';
    }

    function esSoloResena() {
      // Permite actualizar solo los campos de calificación, sin importar el estado del pedido
      return request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['rating', 'resena', 'fechaResena', 'finalizadoCliente']);
    }
  }
}