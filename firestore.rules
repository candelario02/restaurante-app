rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Función para obtener los datos del usuario que intenta entrar
    function getUsuarioData() {
      return get(/databases/$(database)/documents/usuarios_admin/$(request.auth.token.email)).data;
    }

    // Reglas para Productos
    match /productos/{docId} {
      allow read: if true; // Cualquiera puede ver el menú
      // Solo Admin o Superadmin pueden crear/editar/borrar platos
      allow write: if request.auth != null && 
        (getUsuarioData().rol == 'admin' || getUsuarioData().rol == 'superadmin');
    }

    // Reglas para Pedidos
    match /pedidos/{docId} {
      allow create: if true; // Los clientes pueden crear pedidos
      allow read, update: if request.auth != null; // Mozos y Admins pueden ver y gestionar estados
      allow delete: if request.auth != null && getUsuarioData().rol == 'superadmin';
    }

    // Reglas para la colección de Usuarios (Seguridad máxima)
    match /usuarios_admin/{email} {
      // Un usuario puede leer sus propios datos al loguearse
      allow read: if request.auth != null && request.auth.token.email == email;
      // Solo el Superadmin puede ver la lista completa y crear nuevos usuarios
      allow read, write: if request.auth != null && getUsuarioData().rol == 'superadmin';
    }
  }
}