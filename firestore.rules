rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 🔒 FUNCIONES GLOBALES DE APOYO
    function estaAutenticado() {
      return request.auth != null;
    }

    function getUsuarioData() {
      // Importante: El login siempre consulta la colección GLOBAL para saber a qué restaurante pertenece
      return get(/databases/$(database)/documents/usuarios_admin/$(request.auth.token.email)).data;
    }

    function esAdmin() {
      let data = getUsuarioData();
      return data.rol == "admin" || data.rol == "superadmin";
    }

    // 1. 👨‍💼 LOGIN GLOBAL (Solo lectura para que el sistema reconozca al usuario)
    match /usuarios_admin/{email} {
      allow read: if true; 
      allow write: if estaAutenticado() && esAdmin();
    }

    // 2. 🏗️ ESTRUCTURA JERÁRQUICA (RESTAURANTES)
    match /restaurantes/{restId} {
      
      allow read: if true;

      // 🍽️ PRODUCTOS (Ahora dentro de restaurante)
      match /productos/{docId} {
        allow read: if true;
        allow write: if estaAutenticado() && esAdmin() && getUsuarioData().restauranteId == restId;
      }

      // 📝 PEDIDOS (Tu lógica de adicionales y reseñas corregida)
      match /pedidos/{docId} {
        allow read, create: if true;
        allow update: if estaAutenticado() || esAdicional() || esSoloResena();
        allow delete: if estaAutenticado() && esAdmin();
      }

      // 👤 USUARIOS DEL STAFF (Dentro del restaurante)
      match /usuarios_admin/{email} {
        allow read, write: if estaAutenticado() && esAdmin() && getUsuarioData().restauranteId == restId;
      }
    }

    // 🔒 FUNCIONES DE VALIDACIÓN DE PEDIDOS
    function esAdicional() {
      return resource.data.estado == 'pendiente' && 
             request.resource.data.diff(resource.data).affectedKeys()
             .hasAny(['items', 'total', 'fechaActualizacion', 'estado']);
    }

    function esSoloResena() {
      return request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['rating', 'resena', 'fechaResena', 'finalizadoCliente']);
    }

    // ⚙️ CONFIGURACIONES
    match /configuraciones/{docId} {
      allow read: if true;
      allow write: if estaAutenticado() && getUsuarioData().restauranteId == docId;
    }
  }
}