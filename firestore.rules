rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 🔒 FUNCIONES DE APOYO
    function estaAutenticado() {
      return request.auth != null;
    }

    // Obtiene los datos del usuario logueado desde la colección usuarios_admin
    function datosUsuario() {
      return get(/databases/$(database)/documents/usuarios_admin/$(request.auth.token.email)).data;
    }

    // Verifica si el usuario es el dueño del restaurante al que pertenece el documento
    function esAdminDelRestaurante(resId) {
      return estaAutenticado() && datosUsuario().restauranteId == resId && datosUsuario().rol == "admin";
    }

    // Verifica si es personal (Admin o Mozo) del restaurante
    function esPersonalDelRestaurante(resId) {
      return estaAutenticado() && datosUsuario().restauranteId == resId && 
             (datosUsuario().rol == "admin" || datosUsuario().rol == "mozo");
    }

    // 🍽️ PRODUCTOS
    match /productos/{docId} {
      allow read: if true; 
      // Solo el Admin del restaurante específico puede crear/editar/borrar platos
      allow create, update, delete: if esAdminDelRestaurante(request.resource.data.restauranteId || resource.data.restauranteId);
    }

    // 👨‍💼 USUARIOS ADMIN (Perfiles de personal)
    match /usuarios_admin/{email} {
      allow read: if true; 
      // Solo el dueño del correo o un Superadmin puede modificar perfiles
      allow write: if estaAutenticado() && (request.auth.token.email == email || datosUsuario().rol == "superadmin");
    }
    
    // 📝 PEDIDOS
    match /pedidos/{docId} {
      allow create: if true; // Clientes anónimos pueden pedir
      allow read: if true;   // Clientes pueden ver su estado
      // Solo Admin o Mozo del mismo restaurante pueden cambiar el estado del pedido
      allow update: if esPersonalDelRestaurante(resource.data.restauranteId);
      allow delete: if esAdminDelRestaurante(resource.data.restauranteId);
    }

    // ⚙️ CONFIGURACIONES
    match /configuraciones/{docId} {
      allow read: if true;
      allow write: if esAdminDelRestaurante(docId); // Asumiendo que el docId es el restauranteId
    }
  }
}