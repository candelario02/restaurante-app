rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 🔒 FUNCIONES DE APOYO
    function estaAutenticado() {
      return request.auth != null;
    }

    // Verifica si el usuario tiene rol de admin dentro del restaurante específico
    function esAdminDelRestaurante(restId) {
      let adminPath = /databases/$(database)/documents/restaurantes/$(restId)/usuarios_admin/$(request.auth.token.email);
      // exists() evita que la regla explote si el documento aún no ha sido creado
      return estaAutenticado() && exists(adminPath) && get(adminPath).data.rol in ["admin", "superadmin"];
    }

    // 1. PERFIL GLOBAL (Solo para el primer login)
    match /usuarios_admin/{email} {
      allow read: if true;
      allow write: if false; 
    }

    // 2. ESTRUCTURA MULTIPUNTO (RESTAURANTES)
    match /restaurantes/{restId} {
      
      // Permitir leer datos básicos del restaurante (nombre, etc.)
      allow read: if true;

      // 🍽️ PRODUCTOS (Menú)
      match /productos/{docId} {
        allow read: if true; // Cualquiera ve el menú
        allow write: if esAdminDelRestaurante(restId); // Solo admin del local
      }

      // 👤 STAFF DEL LOCAL
      match /usuarios_admin/{email} {
        // El usuario puede leer su propio perfil o el admin del local gestiona todo
        allow read: if estaAutenticado() && (request.auth.token.email == email || esAdminDelRestaurante(restId));
        allow write: if esAdminDelRestaurante(restId);
      }

      // 📝 PEDIDOS
      match /pedidos/{docId} {
        allow read, create: if true; // Clientes crean y ven sus pedidos
        allow update: if estaAutenticado() || esAdicional() || esSoloResena();
        allow delete: if esAdminDelRestaurante(restId);
      }
    }

    // Funciones de validación de pedidos (Sin cambios)
    function esAdicional() {
      return resource.data.estado == 'pendiente' && 
             request.resource.data.diff(resource.data).affectedKeys()
             .hasAny(['items', 'total', 'fechaActualizacion', 'estado']);
    }
    function esSoloResena() {
      return request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['rating', 'resena', 'fechaResena', 'finalizadoCliente']);
    }

    // ⚙️ CONFIGURACIONES DEL LOCAL
    match /configuraciones/{docId} {
      allow read: if true;
      allow write: if esAdminDelRestaurante(restId);
    }
  }
}