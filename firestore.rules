rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 🔒 FUNCIONES DE APOYO
    function estaAutenticado() {
      return request.auth != null;
    }

    // Verifica si el usuario existe en la subcolección del restaurante y tiene el rol
    function esAdminDelRestaurante(restId) {
      let emailLimpio = request.auth.token.email.lower();
      let adminPath = /databases/$(database)/documents/restaurantes/$(restId)/usuarios_admin/$(emailLimpio);
      return estaAutenticado() && exists(adminPath) && get(adminPath).data.rol in ["admin", "superadmin"];
    }

    // 1. ESTRUCTURA MULTIPUNTO (RESTAURANTES)
    match /restaurantes/{restId} {
      allow read: if true;

      // 🍽️ PRODUCTOS
      match /productos/{docId} {
        allow read: if true; 
        allow write: if esAdminDelRestaurante(restId);
      }

      // 👤 STAFF DEL LOCAL (Usuarios dentro de cada restaurante)
      match /usuarios_admin/{email} {
        allow read: if estaAutenticado() && (request.auth.token.email.lower() == email.lower() || esAdminDelRestaurante(restId));
        allow write: if esAdminDelRestaurante(restId);
      }

      // 📝 PEDIDOS
      match /pedidos/{docId} {
        allow read, create: if true;
        allow update: if estaAutenticado() || esAdicional() || esSoloResena();
        allow delete: if esAdminDelRestaurante(restId);
      }
      
      // ⚙️ CONFIGURACIONES (Movido adentro de restaurantes para que restId funcione)
      match /configuraciones/{docId} {
        allow read: if true;
        allow write: if esAdminDelRestaurante(restId);
      }
    }

    // 2. PERFIL GLOBAL (Solo lectura para validación inicial)
    match /usuarios_admin/{email} {
      allow read: if true;
      allow write: if false; 
    }

    // Funciones de validación de pedidos
    function esAdicional() {
      return resource.data.estado == 'pendiente' && 
             request.resource.data.diff(resource.data).affectedKeys()
             .hasAny(['items', 'total', 'fechaActualizacion', 'estado']);
    }
    function esSoloResena() {
      return request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['rating', 'resena', 'fechaResena', 'finalizadoCliente']);
    }
  }
}